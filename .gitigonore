```gitignore
# Virtual environments
.venv/
venv/
env/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Build / distribution
build/
dist/
*.egg-info/
.eggs/

# Jupyter notebooks
.ipynb_checkpoints/

# Environment variables
.env
.env.*

# IDE / editor
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
.pyc

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/

# mypy / lint
.mypy_cache/
.ruff_cache/

# Data files (optional)
*.csv
*.xlsx
*.parquet
```
